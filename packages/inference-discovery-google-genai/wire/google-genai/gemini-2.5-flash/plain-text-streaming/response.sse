data: {"candidates": [{"content": {"parts": [{"text": " the **hull**, the buoyant body that displaces water and provides a platform for the rest of the boat. Beneath the hull, extending deep into the water, is the **keel**. This heavy, often fin-shaped appendage prevents the boat from being"}],"role": "model"},"index": 0}],"usageMetadata": {"promptTokenCount": 33,"candidatesTokenCount": 73,"totalTokenCount": 106,"promptTokensDetails": [{"modality": "TEXT","tokenCount": 33}],"serviceTier": "standard"},"modelVersion": "gemini-2.5-flash","responseId": "JtwNauyyHb_g_uMP0rqx0Ak"}

data: {"candidates": [{"content": {"parts": [{"text": " pushed sideways by the wind (known as \"leeway\") and provides stability, keeping the boat upright.\n\nThe power for propulsion comes from the **sails**. These large fabric airfoils are shaped to catch the wind, creating a pressure"}],"role": "model"},"index": 0}],"usageMetadata": {"promptTokenCount": 33,"candidatesTokenCount": 122,"totalTokenCount": 155,"promptTokensDetails": [{"modality": "TEXT","tokenCount": 33}],"serviceTier": "standard"},"modelVersion": "gemini-2.5-flash","responseId": "JtwNauyyHb_g_uMP0rqx0Ak"}

data: {"candidates": [{"content": {"parts": [{"text": " differential that generates lift, much like an airplane wing. When the wind flows over both sides of a sail, it creates a force that pulls the boat forward, or at least in the general direction the skipper wants to go. The angle of"}],"role": "model"},"index": 0}],"usageMetadata": {"promptTokenCount": 33,"candidatesTokenCount": 170,"totalTokenCount": 203,"promptTokensDetails": [{"modality": "TEXT","tokenCount": 33}],"serviceTier": "standard"},"modelVersion": "gemini-2.5-flash","responseId": "JtwNauyyHb_g_uMP0rqx0Ak"}

