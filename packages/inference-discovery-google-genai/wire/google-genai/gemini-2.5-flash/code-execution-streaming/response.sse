data: {"candidates": [{"content": {"parts": [{"executableCode": {"language": "PYTHON","code": "def fibonacci(n):\n    if n \u003c= 0:\n        return 0\n    elif n == 1:\n        return 1\n    else:\n        a, b = 0, 1\n        for _ in range(2, n + 1):\n            a, b = b, a + b\n        return b\n\nfib_20 = fibonacci(20)\nprint(f'The 20th Fibonacci number is: {fib_20}')"}}],"role": "model"},"index": 0}],"usageMetadata": {"promptTokenCount": 33,"candidatesTokenCount": 108,"totalTokenCount": 191,"promptTokensDetails": [{"modality": "TEXT","tokenCount": 33}],"thoughtsTokenCount": 50,"serviceTier": "standard"},"modelVersion": "gemini-2.5-flash","responseId": "JvQNauuHLqCvjMcPzOqYiA4"}

