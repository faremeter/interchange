{
  "name": "@intx/workflow",
  "description": "Definition surface, state machine, and abstract runtime for multi-step agent workflows",
  "version": "0.2.2",
  "license": "LGPL-2.1-only",
  "type": "module",
  "exports": {
    ".": {
      "intx-src": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./state-machine": {
      "intx-src": "./src/state-machine/index.ts",
      "types": "./dist/state-machine/index.d.ts",
      "default": "./dist/state-machine/index.js"
    },
    "./definition": {
      "intx-src": "./src/definition/index.ts",
      "types": "./dist/definition/index.d.ts",
      "default": "./dist/definition/index.js"
    },
    "./runtime": {
      "intx-src": "./src/runtime/index.ts",
      "types": "./dist/runtime/index.d.ts",
      "default": "./dist/runtime/index.js"
    },
    "./runlocal": {
      "intx-src": "./src/runlocal/index.ts",
      "types": "./dist/runlocal/index.d.ts",
      "default": "./dist/runlocal/index.js"
    }
  },
  "dependencies": {
    "@intx/agent": "workspace:*",
    "@intx/inference": "workspace:*",
    "@intx/types": "workspace:*",
    "arktype": "catalog:"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  }
}
