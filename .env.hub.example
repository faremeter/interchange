DB_USER=interchange-hub
DB_PASSWORD=hub-dev-password
# DB_SSL=true             # enable SSL for the database connection

BETTER_AUTH_SECRET=
BETTER_AUTH_BASE_URL=http://localhost:3000

HUB_DATA_DIR=./tmp/hub-data
# PORT=3000               # override the default hub port

# Per-tarball cap (bytes) for tool packages uploaded to the package
# registry. Defaults to 10 MiB (10485760) when unset; must be a
# positive number.
# HUB_MAX_TARBALL_BYTES=10485760

# PG_SCHEMA pins the hub to a specific postgres schema. Set only by the
# integration-test harness so each spawned hub gets a dedicated,
# droppable schema; leave unset for normal operation.

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
