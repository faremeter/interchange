HUB_WS_URL=ws://localhost:3000/api/sidecars/ws
SIDECAR_ID=dev-sidecar-1
SIDECAR_TOKEN=dev-token
SIDECAR_DATA_DIR=./tmp/sidecar-data

# Directory for the tool-package tarball cache. Defaults to
# <SIDECAR_DATA_DIR>/cache/tarballs when unset.
# SIDECAR_CACHE_DIR=./tmp/sidecar-data/cache/tarballs

# Maximum total size (bytes) of the tarball cache. Defaults to 10 GiB
# (10737418240) when unset; must be a positive number.
# SIDECAR_CACHE_MAX_BYTES=10737418240

# Per-tarball cap (bytes) enforced when pulling from upstream tool
# registries. Defaults to 10 MiB (10485760) when unset; must be a
# positive number. Raise it when pointing at a registry whose curated
# tarballs run larger.
# SIDECAR_REGISTRY_MAX_TARBALL_BYTES=10485760

# Tool-package registries, as a JSON array of {name, url, auth?}
# objects. When unset the sidecar uses the public npmjs registry. Do
# not set it to an empty string — unset the variable instead.
# SIDECAR_TOOL_REGISTRIES=[{"name":"npmjs","url":"https://registry.npmjs.org"}]
