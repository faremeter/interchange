#!/usr/bin/env opsh
# shellcheck shell=bash

opsh::version::require v0.7.0
lib::import step-runner

REPODIR=$(git rev-parse --show-toplevel)
DBPKG="$REPODIR/packages/db"

# Source .env from repo root if it exists
if [[ -f "$REPODIR/.env" ]]; then
	# shellcheck disable=SC1091
	set -a
	source "$REPODIR/.env"
	set +a
	log::info "loaded .env"
fi

step::10::type_check() {
	log::info "running type check..."
	bun run check || log::fatal "type check failed, fix errors before migrating"
}

step::20::generate() {
	log::info "generating migration from schema..."
	bun drizzle-kit generate --config="$DBPKG/drizzle.config.ts" \
		|| log::fatal "drizzle-kit generate failed"
}

step::30::migrate() {
	for var in DB_HOST DB_USER DB_PASSWORD DB_NAME; do
		[[ -n "${!var:-}" ]] || log::fatal "missing required env var: $var"
	done

	log::info "applying migrations..."
	bun drizzle-kit migrate --config="$DBPKG/drizzle.config.ts" \
		|| log::fatal "drizzle-kit migrate failed"
}

steps::run step
