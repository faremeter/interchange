#!/usr/bin/env opsh
# shellcheck shell=bash

opsh::version::require v0.7.0

REPODIR=$(git rev-parse --show-toplevel)

if [[ -f "$REPODIR/.env" ]]; then
	# shellcheck disable=SC1091
	set -a
	source "$REPODIR/.env"
	set +a
	log::info "loaded .env"
fi

if [[ -f "$REPODIR/.env.sidecar" ]]; then
	# shellcheck disable=SC1091
	set -a
	source "$REPODIR/.env.sidecar"
	set +a
	log::info "loaded .env.sidecar"
fi

SIDECAR_PORT=${SIDECAR_PORT:-4097}
OPENCODE_PORT=${OPENCODE_PORT:-4096}

exec bun run --watch "$REPODIR/packages/sidecar/src/main.ts"
