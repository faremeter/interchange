DB_HOST=localhost
DB_PORT=5432
DB_NAME=interchange

# Demo runner (bin/posix-demo, bin/ring-demo)
#
# Shared defaults — agents fall back to these when per-agent vars are unset.
OPENAI_API_KEY=
OPENAI_BASE_URL=http://localhost:4096/v1
OPENAI_MODEL=
ANTHROPIC_API_KEY=
#
# Per-agent overrides for posix-demo (all optional):
#   ALPHA_PROVIDER=openai-compatible   # or "anthropic"
#   ALPHA_BASE_URL=
#   ALPHA_API_KEY=
#   ALPHA_MODEL=
#   BETA_PROVIDER=anthropic
#   BETA_BASE_URL=
#   BETA_API_KEY=
#   BETA_MODEL=
#
# Per-agent overrides for ring-demo (all optional):
#   RING_PROVIDER=openai-compatible    # or "anthropic"
#   RING_BASE_URL=
#   RING_API_KEY=
#   RING_MODEL=
#   RING_PROMPT=
#
DEMO_SEED=

# Dev orchestration overrides (bin/dev.ts, bin/seed.ts)
#
# bin/dev.ts publishes the seed tool packages as the seed admin against
# the seed tenant. Set these to point it at a non-seed hub without
# editing the script. Unset values fall back to the seed defaults shown.
#   HUB_ADMIN_EMAIL=alice@example.com
#   HUB_ADMIN_PASSWORD=password123
#   HUB_TENANT_SLUG=acme
#   HUB_TENANT_NAME=Acme Corp
#
# Base URL bin/seed.ts targets when seeding via the hub API.
#   HUB_URL=http://localhost:3000
