DB_HOST=localhost
DB_PORT=5432
DB_NAME=interchange

# Demo runner (bin/posix-demo)
#
# Shared defaults — agents fall back to these when ALPHA_*/BETA_* are unset.
OPENAI_API_KEY=
OPENAI_BASE_URL=http://localhost:4096/v1
OPENAI_MODEL=
ANTHROPIC_API_KEY=
#
# Per-agent overrides (all optional — defaults above are used when unset):
#   ALPHA_PROVIDER=openai-compatible   # or "anthropic"
#   ALPHA_BASE_URL=
#   ALPHA_API_KEY=
#   ALPHA_MODEL=
#   BETA_PROVIDER=anthropic
#   BETA_BASE_URL=
#   BETA_API_KEY=
#   BETA_MODEL=
#
DEMO_TURNS=10
DEMO_SEED=
