#!/usr/bin/env -S bun --conditions=intx-src
// The intx-src condition resolves @intx/* to TypeScript source. The
// sidecar spawns this child by path (`Bun.spawn([binaryPath])`) and
// `--conditions` is not inherited, so it is set on the shebang. The dev
// loop builds no dist; a bundled deployment does not run this file.
import { runWorkflowChildFromProcessEnv } from "@intx/workflow-host";
import {
  SIDECAR_SUBSTRATE_CONFIG_KEYS,
  createSubstrate,
} from "../src/workflow-substrate-factory";

await runWorkflowChildFromProcessEnv(createSubstrate, {
  substrateConfigKeys: SIDECAR_SUBSTRATE_CONFIG_KEYS,
});
