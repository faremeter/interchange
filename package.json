{
  "name": "interchange",
  "license": "LGPL-2.1-only",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*",
    "examples/*"
  ],
  "catalog": {
    "arktype": "^2.1.29"
  },
  "scripts": {
    "check": "tsc -b --noEmit",
    "lint": "prettier -c . && eslint --cache . && bun run check:docs",
    "format": "prettier -w .",
    "test": "bun test && bun test tests/hub-agent/deploy-flow.test.ts tests/inference/transform-cutover.test.ts tests/skill-attachment-flow.test.ts tests/hub-api/lib/git-harness.test.ts tests/hub-api/git-*.test.ts",
    "docs": "bun bin/gen-api-docs.ts",
    "check:docs": "bun bin/gen-api-docs.ts --check"
  },
  "devDependencies": {
    "@eslint/js": "9.34.0",
    "@types/bun": "1.3.9",
    "drizzle-kit": "^0.31.9",
    "eslint": "9.34.0",
    "jiti": "2.5.1",
    "prettier": "3.6.2",
    "tsx": "4.20.5",
    "typescript": "5.9.3",
    "typescript-eslint": "8.42.0",
    "zx": "^8.8.5"
  }
}
